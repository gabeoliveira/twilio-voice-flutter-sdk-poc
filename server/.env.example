# Twilio credentials for the token server.
# Copy to .env and fill in. Do NOT commit .env.

# Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=

# API Key SID (starts with SK...) and its Secret — create one in the Twilio Console
# or with: twilio api:core:keys:create --friendly-name "flutter-voice-demo"
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# TwiML App SID (starts with AP...). Its Voice Request URL must point at
# POST <public-url>/voice (use a tunnel like ngrok in dev).
TWILIO_TWIML_APP_SID=

# A Voice-capable Twilio number in E.164, used as caller ID for outbound PSTN.
TWILIO_CALLER_ID=

PORT=3000
